# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA envie o arquivo .env para o GitHub

# Ambiente de execução: 'console' para desenvolvimento, 'gmail' para produção
EMAIL_BACKEND_TIPO=console

# Credenciais do Gmail (necessárias apenas quando EMAIL_BACKEND_TIPO=gmail)
# Para gerar a senha de app: Conta Google → Segurança → Senhas de app
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
